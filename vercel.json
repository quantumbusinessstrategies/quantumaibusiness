{
  "crons": [
    {
      "path": "/api/daily-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/campaign-batch",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/social-queue",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
